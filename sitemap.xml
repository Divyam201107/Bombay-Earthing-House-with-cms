---
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<url><loc>{{ site.url }}/</loc><priority>1.0</priority></url>
<url><loc>{{ site.url }}/about.html</loc><priority>0.8</priority></url>
<url><loc>{{ site.url }}/products.html</loc><priority>0.9</priority></url>
{% for product in site.products %}<url><loc>{{ product.url | absolute_url }}</loc><priority>0.85</priority></url>
{% endfor %}<url><loc>{{ site.url }}/quality-policy.html</loc><priority>0.6</priority></url>
<url><loc>{{ site.url }}/contact.html</loc><priority>0.7</priority></url>
<url><loc>{{ site.url }}/blog-index.html</loc><priority>0.6</priority></url>
{% for post in site.posts %}<url><loc>{{ post.url | absolute_url }}</loc><priority>0.5</priority></url>
{% endfor %}</urlset>
